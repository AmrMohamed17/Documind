# MLflow
MLFLOW_TRACKING_URI=sqlite:////absolute/path/to/mlflow.db
MLFLOW_ARTIFACT_ROOT=gs://your-bucket/mlflow-artifacts

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials/gcp-key.json

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2
